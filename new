<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=yes">
    <title>Kazi Shahbaz // Full Stack Developer | Modern Brutalist Portfolio</title>
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- AOS CSS Library for Scroll Animations -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Syne:wght@700;800&display=swap');

        /* --- Neo-Brutalist Theme Variables --- */
        :root {
            --bg-canvas: #f4f2ed;
            --text-dark: #121212;
            --accent-yellow: #ffde4d;
            --accent-blue: #3b82f6;
            --accent-pink: #ec4899;
            --accent-cyan: #06b6d4;
            --accent-green: #10b981;
            --accent-orange: #f59e0b;
            --accent-purple: #8b5cf6;
            --card-bg: #ffffff;
            --brutal-shadow: 5px 5px 0px #121212;
            --brutal-shadow-hover: 8px 8px 0px #121212;
            --border-thick: 2.5px solid #121212;
            --transition: all 0.25s cubic-bezier(0.2, 0.9, 0.4, 1.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Space Grotesk', sans-serif;
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--bg-canvas);
            color: var(--text-dark);
            overflow-x: hidden;
            padding-bottom: 3rem;
        }

        /* ========== LOADING ANIMATION ========== */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--bg-canvas);
            z-index: 9999;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            gap: 1.5rem;
            transition: opacity 0.6s ease, visibility 0.6s ease;
        }
        .loading-overlay.hide { opacity: 0; visibility: hidden; }
        .brutal-loader {
            width: 65px;
            height: 65px;
            border: var(--border-thick);
            background: var(--card-bg);
            box-shadow: var(--brutal-shadow);
            animation: brutalShake 0.7s infinite alternate;
            position: relative;
        }
        .brutal-loader::before {
            content: "{ }";
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-weight: 800;
            font-size: 1.4rem;
            font-family: 'Syne', monospace;
            color: var(--accent-blue);
        }
        @keyframes brutalShake {
            0% { transform: translate(0,0) rotate(0deg); box-shadow: 3px 3px 0px #121212; }
            100% { transform: translate(-3px,-3px) rotate(-2deg); box-shadow: 6px 6px 0px #121212; }
        }
        .loading-text {
            font-weight: 700;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            background: var(--text-dark);
            color: #fff;
            padding: 0.4rem 1.2rem;
            border: var(--border-thick);
        }
        .loading-progress {
            width: 220px;
            height: 12px;
            background: #fff;
            border: var(--border-thick);
            box-shadow: 2px 2px 0px #121212;
            overflow: hidden;
        }
        .loading-progress-fill {
            width: 0%;
            height: 100%;
            background: var(--accent-yellow);
            transition: width 0.3s ease;
        }
        .main-content { opacity: 0; transition: opacity 0.5s ease; }
        .main-content.visible { opacity: 1; }

        .container {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1.2rem;
        }

        /* --- Brutalist Components --- */
        .brutal-block {
            background: var(--card-bg);
            border: var(--border-thick);
            box-shadow: var(--brutal-shadow);
            padding: 1.5rem;
            transition: var(--transition);
        }
        .brutal-block:hover {
            transform: translate(-3px, -3px);
            box-shadow: var(--brutal-shadow-hover);
        }
        
        .brutal-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
            background: var(--accent-yellow);
            color: var(--text-dark);
            padding: 0.7rem 1.2rem;
            font-weight: 700;
            text-decoration: none;
            border: var(--border-thick);
            box-shadow: 3px 3px 0px #121212;
            cursor: pointer;
            transition: var(--transition);
            font-size: 0.85rem;
            text-transform: uppercase;
            min-height: 44px;
        }
        .brutal-btn:hover {
            transform: translate(-3px, -3px);
            box-shadow: 5px 5px 0px #121212;
            background: #fff;
        }

        h1, h2, h3, .logo { font-family: 'Syne', sans-serif; font-weight: 800; text-transform: uppercase; }
        .section-header {
            margin: 3rem 0 1.8rem 0;
            display: inline-block;
            background: var(--text-dark);
            color: #fff;
            padding: 0.4rem 1.2rem;
            transform: rotate(-0.5deg);
            font-size: 1.4rem;
        }

        /* --- Navigation --- */
        header {
            border-bottom: var(--border-thick);
            background: #fff;
            position: sticky;
            top: 0;
            z-index: 100;
            padding: 0.5rem 0;
        }
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.8rem;
        }
        .logo {
            font-size: 1.3rem;
            background: var(--text-dark);
            color: #fff;
            padding: 0.2rem 0.7rem;
        }
        .nav-links {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            list-style: none;
        }
        .nav-links a {
            text-decoration: none;
            color: var(--text-dark);
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.75rem;
            padding: 0.4rem 0.5rem;
            transition: var(--transition);
            white-space: nowrap;
        }
        .nav-links a:hover { background: var(--accent-yellow); transform: translate(-1px, -1px); }

        /* ========== BREAKOUT IMAGE ========== */
        .hero-grid {
            display: flex;
            flex-direction: column;
            gap: 2rem;
            margin: 2rem 0 1rem;
        }
        @media (min-width: 850px) {
            .hero-grid {
                display: grid;
                grid-template-columns: 1.2fr 0.8fr;
                flex-direction: row;
                align-items: center;
                margin-top: 3rem;
            }
            .breakout-wrapper { order: 2; }
        }

        .breakout-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 1rem 0;
            perspective: 600px;
        }
        .image-stack {
            position: relative;
            width: 260px;
            height: 280px;
            transition: transform 0.3s ease;
        }
        .image-stack:hover {
            transform: translateY(-8px);
        }
        @media (min-width: 550px) {
            .image-stack { width: 300px; height: 320px; }
        }
        @media (min-width: 900px) {
            .image-stack { width: 340px; height: 360px; }
        }

        .profile-breakout {
            position: relative;
            width: 100%;
            z-index: 10;
            filter: drop-shadow(6px 8px 0px #121212);
        }
        .profile-breakout img {
            width: 100%;
            height: auto;
            aspect-ratio: 1 / 1;
            display: block;
            border: var(--border-thick);
            background: linear-gradient(145deg, #faf7f0, #ffffff);
            object-fit: cover;
        }
        .breakout-backdrop {
            position: absolute;
            top: 18px;
            left: -18px;
            width: 100%;
            height: 100%;
            background: var(--accent-yellow);
            border: var(--border-thick);
            z-index: 0;
            transition: all 0.25s ease;
        }
        .image-stack:hover .breakout-backdrop {
            top: 24px;
            left: -24px;
            background: var(--accent-pink);
        }
        .breakout-accent {
            position: absolute;
            bottom: -16px;
            right: -20px;
            width: 65px;
            height: 65px;
            background: var(--accent-blue);
            border: var(--border-thick);
            z-index: 5;
            rotate: 10deg;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.25s ease;
        }
        .breakout-accent::before {
            content: "⚡";
            font-size: 1.8rem;
            color: white;
        }
        .image-stack:hover .breakout-accent {
            bottom: -24px;
            right: -28px;
            rotate: 18deg;
            background: var(--accent-cyan);
        }
        .floating-badge {
            position: absolute;
            top: -12px;
            right: -10px;
            background: var(--accent-pink);
            color: white;
            padding: 0.25rem 0.7rem;
            font-weight: 800;
            font-size: 0.65rem;
            border: var(--border-thick);
            transform: rotate(6deg);
            z-index: 20;
            white-space: nowrap;
            box-shadow: 2px 2px 0 #121212;
        }

        .hero-text h1 {
            font-size: 2.4rem;
            line-height: 1.2;
            margin-bottom: 1rem;
        }
        @media (min-width: 550px) { .hero-text h1 { font-size: 3rem; } }
        @media (min-width: 900px) { .hero-text h1 { font-size: 3.5rem; } }
        .hero-text h1 span {
            background: var(--accent-blue);
            color: #fff;
            padding: 0 0.4rem;
            display: inline-block;
        }
        .hero-text p {
            font-size: 1rem;
            font-weight: 500;
            margin: 1rem 0;
            line-height: 1.45;
        }
        .internship-highlight {
            background: var(--accent-yellow);
            border: var(--border-thick);
            padding: 0.6rem;
            text-align: center;
            font-weight: 800;
            font-size: 0.75rem;
            text-transform: uppercase;
            margin-bottom: 1.2rem;
            transition: var(--transition);
        }
        .internship-highlight:hover {
            transform: translate(-2px, -2px);
            box-shadow: 3px 3px 0px #121212;
        }
        .soft-skills-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 0.6rem;
            margin: 1.2rem 0;
        }
        .soft-skill {
            background: #fff;
            border: 2px solid #121212;
            padding: 0.3rem 0.8rem;
            font-weight: 600;
            font-size: 0.7rem;
            text-transform: uppercase;
            transition: var(--transition);
        }
        .soft-skill:hover {
            transform: translate(-2px, -2px);
            box-shadow: 2px 2px 0px #121212;
            background: var(--accent-yellow);
        }

        /* ========== TOOLKIT SECTION ========== */
        .toolkit-showcase {
            margin: 2rem 0 1rem;
            padding: 1.5rem 0;
        }
        .skills-container {
            display: flex;
            flex-wrap: wrap;
            gap: 0.8rem;
            justify-content: center;
        }
        .skill-pill {
            background: #fff;
            border: var(--border-thick);
            padding: 0.6rem 1.2rem;
            font-weight: 700;
            font-size: 0.9rem;
            box-shadow: 3px 3px 0px #121212;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
        }
        .skill-pill:hover {
            transform: translate(-3px, -3px);
            box-shadow: 5px 5px 0px #121212;
            background: var(--accent-yellow);
        }
        .toolkit-intro {
            text-align: center;
            font-weight: 600;
            margin-bottom: 1.2rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* ========== PROJECTS WITH ENHANCED BUTTON HOVER STYLES ========== */
        .projects-stack {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }
        @media (min-width: 550px) { .projects-stack { grid-template-columns: repeat(2, 1fr); } }
        @media (min-width: 950px) { .projects-stack { grid-template-columns: repeat(3, 1fr); } }
        
        .project-card {
            background: var(--card-bg);
            border: var(--border-thick);
            box-shadow: var(--brutal-shadow);
            padding: 1.5rem;
            transition: var(--transition);
            display: flex;
            flex-direction: column;
        }
        .project-card:hover {
            transform: translate(-4px, -4px);
            box-shadow: var(--brutal-shadow-hover);
        }
        
        .project-icon { font-size: 2.2rem; margin-bottom: 0.8rem; transition: var(--transition); }
        .project-card:hover .project-icon { transform: scale(1.05); }
        .project-card h3 { font-size: 1.3rem; margin-bottom: 0.5rem; }
        .project-badge {
            display: inline-block;
            background: var(--accent-blue);
            color: white;
            font-size: 0.65rem;
            padding: 0.2rem 0.7rem;
            margin-bottom: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            width: fit-content;
            transition: var(--transition);
        }
        .project-card:hover .project-badge { background: var(--accent-pink); transform: translate(-1px, -1px); }
        .project-desc {
            font-size: 0.85rem;
            line-height: 1.4;
            margin-bottom: 1rem;
            color: #2c2c2c;
            flex-grow: 1;
        }
        
        /* === ENHANCED PROJECT BUTTONS WITH HOVER EFFECTS === */
        .project-links {
            display: flex;
            gap: 0.8rem;
            margin-top: 0.5rem;
            flex-wrap: wrap;
        }
        
        /* Base button style for project actions */
        .project-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            font-weight: 700;
            font-size: 0.75rem;
            text-transform: uppercase;
            text-decoration: none;
            border: 2px solid #121212;
            transition: all 0.2s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            cursor: pointer;
            background: #fff;
            color: var(--text-dark);
            box-shadow: 2px 2px 0px #121212;
        }
        
        .project-btn i {
            font-size: 0.8rem;
            transition: transform 0.2s ease;
        }
        
        /* HOVER EFFECTS FOR ALL BUTTONS */
        .project-btn:hover {
            transform: translate(-3px, -3px);
            box-shadow: 5px 5px 0px #121212;
        }
        
        .project-btn:hover i {
            transform: scale(1.1);
        }
        
        /* GitHub button style */
        .btn-github {
            background: #1a1a2e;
            color: white;
            border-color: #121212;
        }
        
        .btn-github:hover {
            background: #16213e;
        }
        
        /* Live Demo button style */
        .btn-live {
            background: var(--accent-green);
            color: #121212;
            border-color: #121212;
        }
        
        .btn-live:hover {
            background: #0e9f6e;
        }
        
        /* Demo button (alternative) */
        .btn-demo {
            background: var(--accent-cyan);
            color: #121212;
            border-color: #121212;
        }
        
        .btn-demo:hover {
            background: #0891b2;
        }
        
        /* Code/Repo button */
        .btn-code {
            background: var(--accent-orange);
            color: #121212;
            border-color: #121212;
        }
        
        .btn-code:hover {
            background: #d97706;
        }
        
        /* Tool button (for utilities) */
        .btn-tool {
            background: var(--accent-purple);
            color: white;
            border-color: #121212;
        }
        
        .btn-tool:hover {
            background: #7c3aed;
        }

        /* Business Grid */
        .business-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.5rem;
            margin-top: 1.5rem;
        }
        @media (min-width: 650px) { .business-grid { grid-template-columns: repeat(2, 1fr); } }

        /* Contact */
        .contact-box {
            text-align: center;
            padding: 1.5rem;
        }
        .social-row {
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            margin-top: 1.5rem;
            flex-wrap: wrap;
        }
        .social-icon {
            font-size: 1.6rem;
            color: var(--text-dark);
            transition: var(--transition);
            min-width: 44px;
            text-align: center;
        }
        .social-icon:hover {
            transform: translateY(-5px) scale(1.1);
            color: var(--accent-blue);
        }

        .back-to-top {
            position: fixed;
            bottom: 1.2rem;
            right: 1.2rem;
            background: var(--text-dark);
            color: white;
            width: 44px;
            height: 44px;
            border: var(--border-thick);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--transition);
            z-index: 99;
            box-shadow: 3px 3px 0 #121212;
        }
        .back-to-top:hover {
            transform: translate(-3px, -3px);
            box-shadow: 6px 6px 0 #121212;
            background: var(--accent-blue);
        }

        footer {
            text-align: center;
            margin-top: 3rem;
            font-size: 0.7rem;
            opacity: 0.7;
        }
        @media (max-width: 450px) {
            .container { padding: 0 1rem; }
            .section-header { font-size: 1.2rem; }
            .brutal-btn { padding: 0.5rem 1rem; font-size: 0.75rem; }
            .project-btn { padding: 0.4rem 0.8rem; font-size: 0.7rem; }
            .project-btn i { font-size: 0.7rem; }
        }
    </style>
</head>
<body>

<div class="loading-overlay" id="loadingOverlay">
    <div class="brutal-loader"></div>
    <div class="loading-text">BOOTING SHAHBAZ.DEV</div>
    <div class="loading-progress"><div class="loading-progress-fill" id="progressFill"></div></div>
    <p style="font-weight: 500; font-size: 0.8rem;">Full-stack // Django // React</p>
</div>

<div class="main-content" id="mainContent">
    <header>
        <div class="container navbar">
            <div class="logo">KSBMR.DEV</div>
            <nav>
                <ul class="nav-links">
                    <li><a href="#about">About</a></li>
                    <li><a href="#toolkit">Toolkit</a></li>
                    <li><a href="#work">Projects</a></li>
                    <li><a href="#business">Business</a></li>
                    <li><a href="#contact">Contact</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main>
        <!-- HERO SECTION -->
        <div class="container" id="about">
            <div class="hero-grid">
                <div class="hero-text" data-aos="fade-right" data-aos-duration="800">
                    <div class="internship-highlight" data-aos="zoom-in" data-aos-delay="200">
                        <i class="fa-solid fa-bolt"></i> ACTIVELY SEEKING INTERNSHIP <i class="fa-solid fa-bolt"></i>
                    </div>
                    <h1>Kazi <span>Shahbaz</span><br>Full Stack Developer</h1>
                    <p>Modern web apps with Django, React, and creative problem-solving. Open for internship & junior roles — ready to contribute from day one.</p>
                    <div class="soft-skills-grid">
                        <span class="soft-skill" data-aos="fade-right" data-aos-delay="100">Problem Solving</span>
                        <span class="soft-skill" data-aos="fade-right" data-aos-delay="150">Team Collaboration</span>
                        <span class="soft-skill" data-aos="fade-right" data-aos-delay="200">Clean Code</span>
                        <span class="soft-skill" data-aos="fade-right" data-aos-delay="250">Fast Learner</span>
                    </div>
                    <div style="display: flex; gap: 0.8rem; flex-wrap: wrap;">
                        <a href="#contact" class="brutal-btn" data-aos="flip-up" data-aos-delay="200"><i class="fa-solid fa-paper-plane"></i> Connect</a>
                        <a href="#work" class="brutal-btn" style="background: white;" data-aos="flip-up" data-aos-delay="300"><i class="fa-solid fa-code"></i> Projects</a>
                    </div>
                </div>

                <div class="breakout-wrapper" data-aos="fade-left" data-aos-duration="1000">
                    <div class="image-stack">
                        <div class="breakout-backdrop"></div>
                        <div class="profile-breakout">
                            <img src="https://raw.githubusercontent.com/KSBMR/portfolio/main/por_img.png" 
                                 alt="Kazi Shahbaz" 
                                 id="profileImg"
                                 onerror="this.onerror=null; this.src='https://placehold.co/500x500/3b82f6/white?text=K+S';">
                            <div class="floating-badge">
                                <i class="fa-regular fa-hand-peace"></i> #OPEN_WORK
                            </div>
                        </div>
                        <div class="breakout-accent"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TOOLKIT SECTION -->
        <div class="container" id="toolkit">
            <div class="toolkit-showcase" data-aos="fade-up" data-aos-duration="700">
                <div class="toolkit-intro">
                    <i class="fa-solid fa-cubes"></i> TECHNICAL TOOLKIT // CORE STACK
                </div>
                <div class="skills-container">
                    <span class="skill-pill" data-aos="zoom-in" data-aos-delay="50"><i class="fa-brands fa-python"></i> Python</span>
                    <span class="skill-pill" data-aos="zoom-in" data-aos-delay="100"><i class="fa-brands fa-django"></i> Django</span>
                    <span class="skill-pill" data-aos="zoom-in" data-aos-delay="150"><i class="fa-brands fa-react"></i> React.js</span>
                    <span class="skill-pill" data-aos="zoom-in" data-aos-delay="200"><i class="fa-brands fa-js"></i> JavaScript/TS</span>
                    <span class="skill-pill" data-aos="zoom-in" data-aos-delay="250"><i class="fa-solid fa-database"></i> PostgreSQL</span>
                    <span class="skill-pill" data-aos="zoom-in" data-aos-delay="300"><i class="fa-brands fa-git-alt"></i> Git/GitHub</span>
                    <span class="skill-pill" data-aos="zoom-in" data-aos-delay="350"><i class="fa-solid fa-cloud"></i> REST APIs</span>
                    <span class="skill-pill" data-aos="zoom-in" data-aos-delay="400"><i class="fa-brands fa-css3"></i> Tailwind CSS</span>
                </div>
            </div>
        </div>

        <!-- PROJECTS SECTION WITH FULL HOVER EFFECTS -->
        <div class="container" id="work">
            <div class="section-header" data-aos="fade-right">Development Projects</div>
            <div class="projects-stack">
                
                <!-- Project 1: Online Library -->
                <div class="project-card" data-aos="zoom-in-up" data-aos-delay="100">
                    <div class="project-icon"><i class="fa-solid fa-book"></i></div>
                    <span class="project-badge">Own • Full Stack</span>
                    <h3>Online Library</h3>

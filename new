<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    (function() {
        let progress = 0;
        const progressFill = document.getElementById('progressFill');
        const loadingOverlay = document.getElementById('loadingOverlay');
        const mainContent = document.getElementById('mainContent');
        const interval = setInterval(() => {
            progress += Math.random() * 14;
            if (progress >= 100) {
                clearInterval(interval);
                setTimeout(() => {
                    loadingOverlay.classList.add('hide');
                    mainContent.classList.add('visible');
                    AOS.init({ duration: 600, once: true, offset: 50, easing: 'ease-out-cubic', disable: false });
                }, 400);
            }
            progressFill.style.width = Math.min(progress, 100) + '%';
        }, 100);

        const backBtn = document.getElementById('backToTop');
        if (backBtn) backBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

        const resume = document.getElementById('resumeBtn');
        if (resume) resume.addEventListener('click', (e) => { e.preventDefault(); alert("📄 Resume ready — send me an email and I'll share the PDF!"); });

        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                const hash = this.getAttribute('href');
                if (hash === "#" || hash === "") return;
                const target = document.querySelector(hash);
                if (target) {
                    e.preventDefault();
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });

        const profileImg = document.getElementById('profileImg');
        if (profileImg && profileImg.complete && profileImg.naturalWidth === 0) {
            profileImg.src = 'https://placehold.co/500x500/3b82f6/white?text=K+S';
        }
    })();
</script>
